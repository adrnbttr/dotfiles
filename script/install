#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

have() { command -v "$1" >/dev/null 2>&1; }

version_ge() {
  # usage: version_ge <have> <want>
  # returns 0 if have >= want (sort -V)
  local have_ver="$1" want_ver="$2"
  [[ "$(printf '%s\n%s\n' "$have_ver" "$want_ver" | sort -V | head -n 1)" == "$want_ver" ]]
}

info() { printf "%s\n" "$*"; }
warn() { printf "warn %s\n" "$*" >&2; }
err() { printf "error %s\n" "$*" >&2; }

os="$(uname -s | tr '[:upper:]' '[:lower:]')"

usage() {
  cat <<'EOF'
Usage:
  ./script/install [options]

Options:
  --minimal           Install core CLI deps only
  --no-gui            Skip GUI apps (kitty)
  --no-opencode       Skip installing opencode
  --no-claude         Skip installing Claude Code
  --upgrade           Upgrade already-installed Homebrew packages (macOS only)
  --opencode-version <version>  Install a specific opencode version
  --claude-version <version>    Install a specific Claude Code version
  -h, --help          Show this help
EOF
}

minimal=false
no_gui=false
no_opencode=false
no_claude=false
upgrade=false
opencode_version="${OPENCODE_VERSION:-}"
claude_version="${CLAUDE_VERSION:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --minimal) minimal=true; shift ;;
    --no-gui) no_gui=true; shift ;;
    --no-opencode) no_opencode=true; shift ;;
    --no-claude) no_claude=true; shift ;;
    --upgrade) upgrade=true; shift ;;
    --opencode-version)
      opencode_version="${2:-}"
      if [[ -z "$opencode_version" ]]; then
        err "--opencode-version requires a value"
        exit 2
      fi
      shift 2
      ;;
    --claude-version)
      claude_version="${2:-}"
      if [[ -z "$claude_version" ]]; then
        err "--claude-version requires a value"
        exit 2
      fi
      shift 2
      ;;
    -h|--help) usage; exit 0 ;;
    *)
      err "unknown option: $1"
      usage
      exit 2
      ;;
  esac
done

brew_install_if_missing() {
  local pkg="$1"
  if brew list --versions "$pkg" >/dev/null 2>&1; then
    return 0
  fi
  brew install "$pkg"
}

brew_cask_install_if_missing() {
  local pkg="$1"
  if brew list --cask "$pkg" >/dev/null 2>&1; then
    return 0
  fi
  brew install --cask "$pkg"
}

sudo_cmd=""
if [[ ${EUID:-0} -ne 0 ]]; then
  if have sudo; then
    sudo_cmd="sudo"
  else
    err "need root privileges (install sudo or run as root)"
    exit 1
  fi
fi

install_opencode() {
  if [[ "$no_opencode" == "true" ]]; then
    return 0
  fi
  if have opencode; then
    return 0
  fi
  if ! have curl; then
    err "curl is required to install opencode"
    exit 1
  fi
  info "installing opencode (official installer)"
  if [[ -n "$opencode_version" ]]; then
    curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path --version "$opencode_version"
  else
    curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path
  fi
}

install_claude() {
  if [[ "$no_claude" == "true" ]]; then
    return 0
  fi
  if have claude; then
    info "Claude Code already installed"
    return 0
  fi
  if ! have curl; then
    err "curl is required to install Claude Code"
    exit 1
  fi
  info "installing Claude Code..."
  
  # Use the dedicated installation script
  local install_args=""
  if [[ -n "$claude_version" ]]; then
    install_args="--version \"$claude_version\""
  fi
  
  # Run the Claude installation script
  "$repo_root/script/install-claude" $install_args
  
  if have claude; then
    info "✓ Claude Code installed successfully"
  else
    warn "Claude Code installation may need manual setup"
    warn "Check: ./script/install-claude --help"
  fi
}

install_fzf_release_linux() {
  local ver="${1:-}"
  if [[ -z "$ver" ]]; then
    err "install_fzf_release_linux requires a version"
    exit 2
  fi
  if ! have curl; then
    err "curl is required to install fzf"
    exit 1
  fi
  if ! have tar; then
    err "tar is required to install fzf"
    exit 1
  fi
  if ! have sha256sum; then
    err "sha256sum is required to install fzf"
    exit 1
  fi

  local arch
  case "$(uname -m)" in
    x86_64) arch="linux_amd64" ;;
    aarch64|arm64) arch="linux_arm64" ;;
    *)
      err "unsupported architecture for fzf install: $(uname -m)"
      exit 1
      ;;
  esac

  local url_base="https://github.com/junegunn/fzf/releases/download/v${ver}"
  local file="fzf-${ver}-${arch}.tar.gz"

  info "installing fzf ${ver} (${arch}) to ~/.local/bin/fzf"
  mkdir -p "$HOME/.local/bin"

  local tmpdir
  tmpdir="$(mktemp -d)"
  ( set -euo pipefail
    trap 'rm -rf "$tmpdir"' EXIT
    cd "$tmpdir"
    curl -fsSL -o "$file" "$url_base/$file"
    curl -fsSL -o checksums.txt "$url_base/fzf_${ver}_checksums.txt"
    grep "$file" checksums.txt > expected.txt
    sha256sum -c expected.txt
    tar -xzf "$file"
    install -m 0755 -D ./fzf "$HOME/.local/bin/fzf"
  )
}

ensure_fzf_recent_linux() {
  local min="0.36.0"
  local desired="${FZF_VERSION:-0.67.0}"

  if have fzf; then
    local current
    current="$(fzf --version 2>/dev/null | awk '{print $1}' || true)"
    if [[ -n "$current" ]] && version_ge "$current" "$min"; then
      return 0
    fi
    warn "fzf ${current:-unknown} is too old for fzf-lua (need >= ${min}); installing ${desired}"
  else
    warn "fzf missing; installing ${desired}"
  fi

  install_fzf_release_linux "$desired"
}

install_lazygit_release_linux() {
  local version="${1:-0.44.1}"
  local url="https://github.com/jesseduffield/lazygit/releases/download/v${version}/lazygit_${version}_Linux_x86_64.tar.gz"
  local tmpdir
  tmpdir=$(mktemp -d)
  (
    cd "$tmpdir"
    curl -fsSL -o lazygit.tar.gz "$url" || { err "failed to download lazygit ${version}"; exit 1; }
    tar -xzf lazygit.tar.gz || { err "failed to extract lazygit"; exit 1; }
    install -m 0755 -D ./lazygit "$HOME/.local/bin/lazygit"
  )
  rm -rf "$tmpdir"
}

ensure_lazygit_linux() {
  local version="${LAZYGIT_VERSION:-0.44.1}"

  # Check if force reinstall
  if [[ "${LAZYGIT_FORCE:-}" == "1" ]]; then
    info "LAZYGIT_FORCE=1: reinstalling lazygit ${version}"
    rm -f "$HOME/.local/bin/lazygit"
  elif have lazygit; then
    info "lazygit already installed ($(lazygit --version 2>/dev/null | head -1 | awk '{print $6}'))"
    return 0
  fi

  info "installing lazygit ${version} from GitHub"
  install_lazygit_release_linux "$version"

  # Verify installation
  if have lazygit; then
    ok "lazygit ${version} installed successfully"
  else
    err "lazygit installation failed"
    return 1
  fi
}

install_lazydocker_release_linux() {
  local version="${1:-0.24.4}"
  local url="https://github.com/jesseduffield/lazydocker/releases/download/v${version}/lazydocker_${version}_Linux_x86_64.tar.gz"
  local tmpdir
  tmpdir=$(mktemp -d)
  (
    cd "$tmpdir"
    curl -fsSL -o lazydocker.tar.gz "$url" || { err "failed to download lazydocker ${version}"; exit 1; }
    tar -xzf lazydocker.tar.gz || { err "failed to extract lazydocker"; exit 1; }
    install -m 0755 -D ./lazydocker "$HOME/.local/bin/lazydocker"
  )
  rm -rf "$tmpdir"
}

ensure_lazydocker_linux() {
  local version="${LAZYDOCKER_VERSION:-0.24.4}"

  # Check if force reinstall
  if [[ "${LAZYDOCKER_FORCE:-}" == "1" ]]; then
    info "LAZYDOCKER_FORCE=1: reinstalling lazydocker ${version}"
    rm -f "$HOME/.local/bin/lazydocker"
  elif have lazydocker; then
    info "lazydocker already installed ($(lazydocker --version 2>/dev/null | head -1 | awk '{print $3}'))"
    return 0
  fi

  info "installing lazydocker ${version} from GitHub"
  install_lazydocker_release_linux "$version"

  # Verify installation
  if have lazydocker; then
    info "lazydocker ${version} installed successfully"
  else
    err "lazydocker installation failed"
    return 1
  fi
}

ensure_pyenv_virtualenv_plugin() {
  local pyenv_root=""
  if have pyenv; then
    pyenv_root="$(pyenv root 2>/dev/null || true)"
  fi
  if [[ -z "$pyenv_root" && -d "$HOME/.pyenv" ]]; then
    pyenv_root="$HOME/.pyenv"
  fi
  if [[ -z "$pyenv_root" ]]; then
    return 0
  fi

  local plugin_dir="$pyenv_root/plugins/pyenv-virtualenv"
  if [[ -d "$plugin_dir" ]]; then
    return 0
  fi
  if ! have git; then
    warn "git not found; cannot install pyenv-virtualenv plugin"
    return 0
  fi

  info "installing pyenv-virtualenv plugin"
  mkdir -p "$(dirname "$plugin_dir")"
  git clone --depth=1 https://github.com/pyenv/pyenv-virtualenv.git "$plugin_dir"
}

case "$os" in
  darwin)
    if ! have brew; then
      err "Homebrew not found. Install it from https://brew.sh and re-run."
      exit 1
    fi

    export HOMEBREW_NO_AUTO_UPDATE=1

    info "installing packages (macOS/Homebrew)"

    # Only install missing packages (avoid surprise upgrades).
    brew_install_if_missing git
    brew_install_if_missing stow
    brew_install_if_missing zsh
    brew_install_if_missing fzf
    brew_install_if_missing ripgrep
    brew_install_if_missing fd
    brew_install_if_missing bat
    brew_install_if_missing pyenv
    brew_install_if_missing lazygit
    brew_install_if_missing lazydocker
    # Needed by vim-dadbod for PostgreSQL queries
    brew_install_if_missing libpq

    if [[ "$minimal" != "true" ]]; then
      brew_install_if_missing autojump
      brew_install_if_missing neovim
    fi

    if [[ "$upgrade" == "true" ]]; then
      info "upgrading packages (macOS/Homebrew)"
      brew upgrade git stow zsh fzf ripgrep fd bat pyenv lazygit || true
      if [[ "$minimal" != "true" ]]; then
        brew upgrade autojump neovim || true
      fi
    fi

    # kitty is a cask; it may already exist outside brew management.
    if [[ "$minimal" != "true" && "$no_gui" != "true" ]]; then
      if ! brew_cask_install_if_missing kitty >/dev/null 2>&1; then
        warn "kitty cask install skipped (kitty.app already present?)"
      fi
    fi

    ensure_pyenv_virtualenv_plugin
    install_opencode
    install_claude

    # Install modern terminal tools (via Homebrew)
    if [[ "$minimal" != "true" ]]; then
      brew_install_if_missing eza
      brew_install_if_missing zoxide
      brew_install_if_missing git-delta
      brew_install_if_missing bottom
    fi
    ;;

  linux)
    if ! have apt-get; then
      err "apt-get not found (this installer currently supports apt-based distros)"
      exit 1
    fi

    info "installing packages (Linux/apt)"
    
    # Install lazygit first (before apt to avoid dependency on apt repositories)
    ensure_lazygit_linux
    ensure_lazydocker_linux

    ${sudo_cmd} apt-get update || true

    required_pkgs=(
      ca-certificates
      curl
      git
      stow
      zsh
      fzf
      ripgrep
      fd-find
      bat
      tar
      # Needed by vim-dadbod for PostgreSQL queries
      postgresql-client
    )

    ${sudo_cmd} apt-get install -y "${required_pkgs[@]}"

    # fzf-lua (Neovim) requires fzf >= 0.36, but Ubuntu jammy ships 0.29.
    ensure_fzf_recent_linux

    # Install modern terminal tools
    ensure_eza_linux
    ensure_zoxide_linux
    ensure_delta_linux
    ensure_bottom_linux

    if [[ "$minimal" != "true" ]]; then
      optional_pkgs=(autojump neovim)
      if [[ "$no_gui" != "true" ]]; then
        optional_pkgs+=(kitty)
      fi

      if ! ${sudo_cmd} apt-get install -y "${optional_pkgs[@]}"; then
        warn "some optional packages failed to install: ${optional_pkgs[*]}"
      fi
    fi

    ensure_pyenv_virtualenv_plugin
    install_opencode
    install_claude
    ;;

  *)
    err "unsupported OS: $os"
    exit 1
    ;;
esac

info "running bootstrap (stow + config)"
"$repo_root/script/bootstrap"

info "done"

# Modern terminal tools installation
install_eza_release_linux() {
  local version="${1:-0.18.24}"
  local arch
  case "$(uname -m)" in
    x86_64) arch="x86_64" ;;
    aarch64|arm64) arch="aarch64" ;;
    *) err "unsupported architecture for eza install: $(uname -m)"; exit 1 ;;
  esac
  
  local url="https://github.com/eza-community/eza/releases/download/v${version}/eza_${arch}-unknown-linux-gnu.tar.gz"
  local tmpdir
  tmpdir=$(mktemp -d)
  (
    cd "$tmpdir"
    curl -fsSL -o eza.tar.gz "$url" || { err "failed to download eza ${version}"; exit 1; }
    tar -xzf eza.tar.gz || { err "failed to extract eza"; exit 1; }
    install -m 0755 -D ./eza "$HOME/.local/bin/eza"
  )
  rm -rf "$tmpdir"
}

ensure_eza_linux() {
  local version="${EZA_VERSION:-0.18.24}"
  
  if [[ "${EZA_FORCE:-}" == "1" ]]; then
    info "EZA_FORCE=1: reinstalling eza ${version}"
    rm -f "$HOME/.local/bin/eza"
  elif have eza; then
    info "eza already installed ($(eza --version 2>/dev/null | head -1))"
    return 0
  fi
  
  info "installing eza ${version} from GitHub"
  install_eza_release_linux "$version"
  
  if have eza; then
    info "eza ${version} installed successfully"
  else
    err "eza installation failed"
    return 1
  fi
}

install_zoxide_release_linux() {
  local version="${1:-0.9.4}"
  local url="https://github.com/ajeetdsouza/zoxide/releases/download/v${version}/zoxide-${version}-x86_64-unknown-linux-musl.tar.gz"
  local tmpdir
  tmpdir=$(mktemp -d)
  (
    cd "$tmpdir"
    curl -fsSL -o zoxide.tar.gz "$url" || { err "failed to download zoxide ${version}"; exit 1; }
    tar -xzf zoxide.tar.gz || { err "failed to extract zoxide"; exit 1; }
    install -m 0755 -D ./zoxide "$HOME/.local/bin/zoxide"
  )
  rm -rf "$tmpdir"
}

