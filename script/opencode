#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

run_doctor_checks() {
  echo "🔍 OpenCode Doctor - Running health checks..."
  echo ""
  
  # Check 1: OpenCode installation
  echo "1. OpenCode Installation"
  if command -v opencode >/dev/null 2>&1; then
    opencode_version=$(opencode --version 2>/dev/null || echo "unknown")
    echo "   ✓ Installed: v$opencode_version"
  else
    echo "   ✗ NOT INSTALLED"
    echo "   → Run: curl -fsSL https://opencode.ai/install.sh | sh"
  fi
  
  echo ""
  
  # Check 2: Running status
  echo "2. Running Status"
  pid=$(pgrep -f "opencode.*--port" | head -1)
  if [[ -n "$pid" ]]; then
    rss_mb=$(ps -p "$pid" -o rss= | awk '{print int($1/1024)}')
    uptime=$(ps -p "$pid" -o etime= | xargs)
    echo "   ✓ Running: PID $pid (${uptime} uptime)"
    echo "   → RSS: ${rss_mb}MB"
    
    if [[ "$rss_mb" -gt 500 ]]; then
      echo "   ⚠️  High memory (>500MB)"
      echo "   → Run: ./script/opencode memory cleanup"
    fi
    
    if [[ "$rss_mb" -gt 800 ]]; then
      echo "   🚨 Critical memory (>800MB)"
      echo "   → Run: ./script/opencode memory restart"
    fi
  else
    echo "   ✗ NOT RUNNING"
    echo "   → Start with: opencode"
  fi
  
  echo ""
  
  # Check 3: Configuration files
  echo "3. Configuration Files"
  local config_ok=true
  local config_files=(
    "$HOME/.config/opencode/opencode.json"
    "$HOME/.config/opencode/tui.json"
    "$HOME/.config/opencode/env.sh"
  )
  
  for file in "${config_files[@]}"; do
    if [[ -f "$file" ]]; then
      echo "   ✓ $(basename "$file")"
    else
      echo "   ✗ $(basename "$file") - MISSING"
      config_ok=false
    fi
  done
  
  if [[ "$config_ok" == "false" ]]; then
    echo "   → Run: ./script/opencode setup apply"
  fi
  
  echo ""
  
  # Check 4: State files
  echo "4. State Files"
  local state_ok=true
  local state_files=(
    "$HOME/.local/state/opencode/kv.json"
    "$HOME/.local/state/opencode/model.json"
    "$HOME/.local/state/opencode/system_prompt.md"
  )
  
  for file in "${state_files[@]}"; do
    if [[ -f "$file" ]]; then
      echo "   ✓ $(basename "$file")"
    else
      echo "   ✗ $(basename "$file") - MISSING"
      state_ok=false
    fi
  done
  
  if [[ "$state_ok" == "false" ]]; then
    echo "   → Run: ./script/opencode sync pull"
  fi
  
  echo ""
  
  # Check 5: Environment
  echo "5. Environment"
  if [[ -f "$HOME/.config/opencode/env.sh" ]]; then
    if grep -q "source.*env.sh" "$HOME/.zshrc" 2>/dev/null || \
       grep -q "source.*env.sh" "$HOME/.bashrc" 2>/dev/null; then
      echo "   ✓ Environment configured in shell"
    else
      echo "   ⚠️  Environment not sourced in shell"
      echo "   → Run: ./script/opencode setup env"
    fi
  else
    echo "   ✗ Environment file missing"
  fi
  
  echo ""
  
  # Check 6: Cache size
  echo "6. Cache & Storage"
  local cache_dir="$HOME/.cache/opencode"
  local state_dir="$HOME/.local/state/opencode"
  
  if [[ -d "$cache_dir" ]]; then
    cache_size=$(du -sh "$cache_dir" 2>/dev/null | cut -f1)
    echo "   ✓ Cache: $cache_size"
    
    # Check for large cache
    cache_mb=$(du -sm "$cache_dir" 2>/dev/null | cut -f1)
    if [[ "$cache_mb" -gt 100 ]]; then
      echo "   ⚠️  Large cache (>100MB)"
      echo "   → Run: ./script/opencode memory cleanup"
    fi
  else
    echo "   ✓ Cache: Not yet created"
  fi
  
  if [[ -f "$state_dir/prompt-history.jsonl" ]]; then
    history_lines=$(wc -l < "$state_dir/prompt-history.jsonl" 2>/dev/null || echo "0")
    echo "   ✓ History: $history_lines sessions"
    
    if [[ "$history_lines" -gt 1000 ]]; then
      echo "   ⚠️  Large history (>1000 sessions)"
      echo "   → Run: ./script/opencode memory cleanup"
    fi
  fi
  
  echo ""
  echo "📋 Summary:"
  echo "  Run './script/opencode setup apply' to fix configuration issues"
  echo "  Run './script/opencode memory cleanup' to free up space"
  echo "  Run './script/opencode status' for detailed status"
}

show_logo() {
  cat <<'EOF'
   ___                    _                  
  / _ \ _ __   ___   ___ | | ___   ___  ___ 
 | | | | '_ \ / _ \ / _ \| |/ _ \ / __|/ _ \
 | |_| | |_) | (_) | (_) | | (_) | (__  __/
  \___/| .__/ \___/ \___/|_|\___/ \___|\___|
       |_|                                  
  Dotfiles OpenCode Manager v1.0
EOF
}

usage() {
  show_logo
  cat <<'EOF'

Usage:
  ./script/opencode <command> [options]

Commands:
  setup        Configure opencode with performance optimizations
  memory       Manage memory and monitor usage
  sync         Synchronize configuration with dotfiles
  status       Show current configuration and status
  doctor       Run health checks and diagnostics
  help         Show this help message

Quick reference:
  ./script/opencode setup apply     # Apply all optimizations
  ./script/opencode memory monitor  # Check memory usage
  ./script/opencode sync push       # Save config to dotfiles
  ./script/opencode status          # Show current status
  ./script/opencode doctor          # Run health checks

For detailed help on a command:
  ./script/opencode <command> --help
EOF
}

setup_usage() {
  cat <<'EOF'
OpenCode Setup Manager

Usage:
  ./script/opencode setup <command> [options]

Commands:
  apply        Apply performance optimizations
  reset        Reset to default configuration
  env          Update shell environment
  help         Show this help

Examples:
  ./script/opencode setup apply      # Apply all optimizations
  ./script/opencode setup reset      # Reset configuration
  ./script/opencode setup env        # Add to shell profile
EOF
}

memory_usage() {
  cat <<'EOF'
OpenCode Memory Manager

Usage:
  ./script/opencode memory <command> [options]

Commands:
  monitor      Monitor opencode memory usage
  cleanup      Clean up old sessions and cache
  restart      Restart opencode if memory is high
  stats        Show detailed memory statistics
  optimize     Apply memory optimizations
  help         Show this help

Examples:
  ./script/opencode memory monitor   # Check memory usage
  ./script/opencode memory cleanup   # Clean cache
  ./script/opencode memory restart   # Restart if >800MB
  ./script/opencode memory stats     # Show detailed stats
EOF
}

sync_usage() {
  cat <<'EOF'
OpenCode Configuration Synchronizer

Usage:
  ./script/opencode sync <command> [options]

Commands:
  push         Copy local state into repo templates
  pull         Copy repo templates into local state
  help         Show this help

Options:
  --force      Force overwrite local state (with pull)

Examples:
  ./script/opencode sync push        # Save config to dotfiles
  ./script/opencode sync pull        # Apply templates
  ./script/opencode sync pull --force # Overwrite local config
EOF
}

show_status() {
  echo "=== OpenCode Status ==="
  echo ""
  
  # Check if opencode is installed
  if command -v opencode >/dev/null 2>&1; then
    opencode_version=$(opencode --version 2>/dev/null || echo "unknown")
    echo "✓ OpenCode installed: v$opencode_version"
    
    # Check running processes
    pid=$(pgrep -f "opencode.*--port" | head -1)
    if [[ -n "$pid" ]]; then
      rss_mb=$(ps -p "$pid" -o rss= | awk '{print int($1/1024)}')
      echo "✓ Running: PID $pid, RSS: ${rss_mb}MB"
      
      if [[ "$rss_mb" -gt 500 ]]; then
        echo "  ⚠️  High memory (>500MB)"
      fi
      if [[ "$rss_mb" -gt 800 ]]; then
        echo "  🚨 Critical memory (>800MB)"
      fi
    else
      echo "✗ Not running"
    fi
  else
    echo "✗ OpenCode not installed"
  fi
  
  echo ""
  
  # Check config files
  echo "Configuration:"
  local config_files=(
    "$HOME/.config/opencode/opencode.json"
    "$HOME/.config/opencode/tui.json"
    "$HOME/.config/opencode/env.sh"
  )
  
  for file in "${config_files[@]}"; do
    if [[ -f "$file" ]]; then
      echo "  ✓ $(basename "$file")"
    else
      echo "  ✗ $(basename "$file")"
    fi
  done
  
  echo ""
  
  # Check state files
  echo "State files:"
  local state_files=(
    "$HOME/.local/state/opencode/kv.json"
    "$HOME/.local/state/opencode/model.json"
    "$HOME/.local/state/opencode/system_prompt.md"
  )
  
  for file in "${state_files[@]}"; do
    if [[ -f "$file" ]]; then
      echo "  ✓ $(basename "$file")"
    else
      echo "  ✗ $(basename "$file")"
    fi
  done
  
  echo ""
  echo "Use './script/opencode setup apply' to configure"
}

# Main command routing
main_command="${1:-}"
sub_command="${2:-}"

case "$main_command" in
  setup)
    case "$sub_command" in
      apply)
        "$repo_root/script/opencode-setup" --apply
        ;;
      reset)
        "$repo_root/script/opencode-setup" --reset
        ;;
      env)
        "$repo_root/script/opencode-setup" --env
        ;;
      status)
        "$repo_root/script/opencode-setup" --status
        ;;
      ""|-h|--help|help)
        setup_usage
        ;;
      *)
        echo "Unknown setup command: $sub_command"
        setup_usage >&2
        exit 2
        ;;
      *)
        echo "Unknown setup command: $sub_command"
        setup_usage >&2
        exit 2
        ;;
    esac
    ;;
    
  memory)
    case "$sub_command" in
      monitor)
        "$repo_root/script/opencode-memory" monitor
        ;;
      cleanup)
        "$repo_root/script/opencode-memory" cleanup
        ;;
      restart)
        "$repo_root/script/opencode-memory" restart
        ;;
      stats)
        "$repo_root/script/opencode-memory" stats
        ;;
      optimize)
        "$repo_root/script/opencode-memory" optimize
        ;;
""|-h|--help|help)
        memory_usage
        ;;
      *)
        echo "Unknown memory command: $sub_command"
        memory_usage >&2
        exit 2
        ;;
    esac
    ;;
    
  sync)
    case "$sub_command" in
      push)
        "$repo_root/script/opencode-sync" push
        ;;
      pull)
        force="${3:-}"
        "$repo_root/script/opencode-sync" pull "$force"
        ;;
      ""|-h|--help|help)
        sync_usage
        ;;
      *)
        echo "Unknown sync command: $sub_command"
        sync_usage >&2
        exit 2
        ;;
    esac
    ;;
    
  status)
    show_status
    ;;
    
  doctor)
    run_doctor_checks
    ;;
    
  ""|-h|--help)
    usage
    ;;
    
  *)
    echo "Unknown command: $main_command"
    usage >&2
    exit 2
    ;;
esac