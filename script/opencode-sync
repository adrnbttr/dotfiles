#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
Usage:
  ./script/opencode-sync push        Copy local opencode state into the repo templates
  ./script/opencode-sync pull        Copy repo templates into local state (only if missing)
  ./script/opencode-sync pull --force  Overwrite local state from repo templates
EOF
}

cmd="${1:-}"
force="${2:-}"

state_dir="$HOME/.local/state/opencode"
repo_dir="$repo_root/opencode-state/.local/state/opencode"
config_dir="$HOME/.config/opencode"
repo_config_dir="$repo_root/opencode-state/.config/opencode"

ensure_newline() {
  local file="$1"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$file" <<'PY'
import pathlib
import sys

p = pathlib.Path(sys.argv[1])
if not p.exists():
    raise SystemExit(0)
b = p.read_bytes()
if b and not b.endswith(b"\n"):
    p.write_bytes(b + b"\n")
PY
  fi
}

copy_if_missing() {
  local src="$1" dst="$2"
  if [[ ! -f "$src" ]]; then
    echo "  - $(basename "$src") not in repo (skipped)"
    return 0
  fi
  if [[ ! -e "$dst" ]]; then
    mkdir -p "$(dirname "$dst")"
    cp -f "$src" "$dst"
  fi
}

copy_force() {
  local src="$1" dst="$2"
  if [[ ! -f "$src" ]]; then
    echo "  - $(basename "$src") not in repo (skipped)"
    return 0
  fi
  mkdir -p "$(dirname "$dst")"
  cp -f "$src" "$dst"
}

case "$cmd" in
  push)
    mkdir -p "$repo_dir"
    if [[ -f "$state_dir/kv.json" ]]; then
      cp -f "$state_dir/kv.json" "$repo_dir/kv.json"
      ensure_newline "$repo_dir/kv.json"
    fi
    if [[ -f "$state_dir/model.json" ]]; then
      cp -f "$state_dir/model.json" "$repo_dir/model.json"
      ensure_newline "$repo_dir/model.json"
    fi
    if [[ -f "$state_dir/system_prompt.md" ]]; then
      cp -f "$state_dir/system_prompt.md" "$repo_dir/system_prompt.md"
      ensure_newline "$repo_dir/system_prompt.md"
    fi
    
    # Also sync config files
    mkdir -p "$repo_config_dir"
    if [[ -f "$config_dir/opencode.json" ]]; then
      cp -f "$config_dir/opencode.json" "$repo_config_dir/opencode.json"
      ensure_newline "$repo_config_dir/opencode.json"
    fi
    if [[ -f "$config_dir/tui.json" ]]; then
      cp -f "$config_dir/tui.json" "$repo_config_dir/tui.json"
      ensure_newline "$repo_config_dir/tui.json"
    fi
    if [[ -f "$config_dir/env.sh" ]]; then
      cp -f "$config_dir/env.sh" "$repo_config_dir/env.sh"
      ensure_newline "$repo_config_dir/env.sh"
    fi
    ;;

  pull)
    mkdir -p "$state_dir"
    mkdir -p "$config_dir"
    
    if [[ "$force" == "--force" ]]; then
      copy_force "$repo_dir/kv.json" "$state_dir/kv.json"
      copy_force "$repo_dir/model.json" "$state_dir/model.json"
      copy_force "$repo_dir/system_prompt.md" "$state_dir/system_prompt.md"
      
      # Also copy config files
      copy_force "$repo_config_dir/opencode.json" "$config_dir/opencode.json"
      copy_force "$repo_config_dir/tui.json" "$config_dir/tui.json"
      copy_force "$repo_config_dir/env.sh" "$config_dir/env.sh"
    else
      copy_if_missing "$repo_dir/kv.json" "$state_dir/kv.json"
      copy_if_missing "$repo_dir/model.json" "$state_dir/model.json"
      copy_if_missing "$repo_dir/system_prompt.md" "$state_dir/system_prompt.md"
      
      # Also copy config files if missing
      copy_if_missing "$repo_config_dir/opencode.json" "$config_dir/opencode.json"
      copy_if_missing "$repo_config_dir/tui.json" "$config_dir/tui.json"
      copy_if_missing "$repo_config_dir/env.sh" "$config_dir/env.sh"
    fi
    ;;

  ""|-h|--help)
    usage
    ;;

  *)
    usage >&2
    exit 2
    ;;
esac
